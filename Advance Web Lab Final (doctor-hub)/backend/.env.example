# ============================================================
# Doctor Hub Backend — Environment Variables
# Copy this file to .env and fill in your Supabase credentials
# IMPORTANT: Create your Supabase project in ap-southeast-1 (Singapore)
# ============================================================

# Node environment
NODE_ENV=production

# Server port
PORT=5000

# Frontend URL (for CORS) — update for production
FRONTEND_URL=https://your-frontend-url.com

# ============================================================
# Supabase — ap-southeast-1 (Singapore) ONLY
# Get these from: Supabase Dashboard → Project Settings → API
# ============================================================

# Connection pooling URL (use for all Prisma queries)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection URL (use for Prisma migrations)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Supabase project URL
SUPABASE_URL=https://PROJECT_REF.supabase.co

# Supabase anon/public key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (keep secret — server only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
